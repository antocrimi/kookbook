# Copy to .env.local (gitignored) and fill in.
# `supabase status` (in this repo) prints the local values for the public/secret keys.

# ─── Supabase (local) ─────────────────────────────────────────────────────────
# These are the local-dev defaults that ship with `supabase start`. They are
# safe to commit ONLY because they're well-known local-dev keys.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<sb_publishable_...>

# Service role key. Server-only — never expose to the browser.

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get one at https://console.anthropic.com and SET A MONTHLY BUDGET CAP first.
# In production this lives encrypted in `user_api_keys`; for the dev tracer it's
# read directly from the env so you can prove the loop end-to-end.
ANTHROPIC_API_KEY=
